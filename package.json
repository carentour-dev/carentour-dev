{
  "name": "carentour-nextjs",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:webpack": "next build --webpack",
    "start": "next start",
    "lint": "eslint . --max-warnings=0 --ignore-pattern .next --ignore-pattern dist --ignore-pattern supabase/functions",
    "typegen": "next typegen",
    "typecheck": "npm run typegen && tsc --noEmit -p tsconfig.typecheck.json",
    "test": "node --experimental-strip-types --import ./scripts/test-register.mjs --test tests/*.test.ts",
    "smoke": "node tests/live-smoke.mjs",
    "verify:baseline": "npm run lint && npm run typecheck && npm test",
    "verify:release": "npm run verify:baseline && npm run build:webpack",
    "prepare": "husky",
    "format": "prettier --check --cache .",
    "format:write": "prettier --write .",
    "blog:publish-ar": "node ./scripts/publish-arabic-blog-translations.mjs",
    "price-list:template-xlsx": "node ./scripts/generate-price-list-template-xlsx.mjs",
    "price-list:example-xlsx": "node ./scripts/generate-price-list-template-xlsx.mjs --example"
  },
  "engines": {
    "node": "22.x",
    "npm": "11.x"
  },
  "dependencies": {
    "@google/generative-ai": "0.24.1",
    "@hookform/resolvers": "^3.10.0",
    "@radix-ui/react-accordion": "^1.2.11",
    "@radix-ui/react-alert-dialog": "^1.1.14",
    "@radix-ui/react-aspect-ratio": "^1.1.8",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.2",
    "@radix-ui/react-collapsible": "^1.1.11",
    "@radix-ui/react-context-menu": "^2.2.15",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-dropdown-menu": "^2.1.15",
    "@radix-ui/react-hover-card": "^1.1.14",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-menubar": "^1.1.15",
    "@radix-ui/react-navigation-menu": "^1.2.13",
    "@radix-ui/react-popover": "^1.1.14",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-radio-group": "^1.3.7",
    "@radix-ui/react-scroll-area": "^1.2.9",
    "@radix-ui/react-select": "^2.2.5",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slider": "^1.3.5",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.5",
    "@radix-ui/react-tabs": "^1.1.12",
    "@radix-ui/react-toast": "^1.2.14",
    "@radix-ui/react-toggle": "^1.1.9",
    "@radix-ui/react-toggle-group": "^1.1.10",
    "@radix-ui/react-tooltip": "^1.2.7",
    "@supabase/ssr": "^0.7.0",
    "@supabase/supabase-js": "^2.103.0",
    "@tanstack/react-query": "^5.97.0",
    "@tiptap/extension-character-count": "3.10.1",
    "@tiptap/extension-color": "3.10.1",
    "@tiptap/extension-highlight": "3.10.1",
    "@tiptap/extension-image": "3.10.1",
    "@tiptap/extension-link": "3.10.1",
    "@tiptap/extension-placeholder": "3.10.1",
    "@tiptap/extension-text-align": "3.10.1",
    "@tiptap/extension-text-style": "3.10.1",
    "@tiptap/extension-underline": "3.10.1",
    "@tiptap/react": "3.10.1",
    "@tiptap/starter-kit": "3.10.1",
    "@types/react-syntax-highlighter": "15.5.13",
    "cheerio": "1.1.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^3.6.0",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^0.462.0",
    "next": "^16.0.0",
    "next-intl": "4.8.4",
    "next-themes": "^0.4.6",
    "react": "19.2.1",
    "react-day-picker": "^9.14.0",
    "react-dom": "19.2.1",
    "react-hook-form": "7.65.0",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^2.1.9",
    "react-syntax-highlighter": "16.1.0",
    "recharts": "^2.15.4",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "sanitize-html": "2.17.0",
    "sonner": "^1.7.4",
    "tailwind-merge": "^2.6.1",
    "tailwindcss-animate": "^1.0.7",
    "vaul": "^1.1.2",
    "xlsx": "0.18.5",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.16",
    "@types/node": "22.18.9",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.0.0",
    "husky": "9.1.7",
    "lint-staged": "16.2.4",
    "postcss": "^8.5.9",
    "prettier": "3.6.2",
    "prettier-plugin-tailwindcss": "0.6.14",
    "tailwindcss": "^3.4.19",
    "typescript": "^6.0.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,cjs,json,md,css,scss}": [
      "prettier --check --cache"
    ],
    "*.{ts,tsx,js,jsx,mjs,cjs}": [
      "eslint --max-warnings=0"
    ],
    "supabase/functions/**/*.ts": [
      "./scripts/check-deno.sh"
    ],
    "supabase/**/*.sql": [
      "./scripts/check-sqlfluff.sh"
    ]
  }
}
